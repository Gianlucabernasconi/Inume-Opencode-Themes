{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#D8D8E0",
    "surface": "#E8E8F0",
    "neutral": "#8A8A96",
    "snesBlue": "#0055FF",
    "snesRed": "#FF0000",
    "snesYellow": "#FFD700",
    "snesGreen": "#00CC00",
    "text": "#1A1A24",
    "shadowDark": "#9A9AA6"
  },
  "theme": {
    "primary": { "dark": "snesBlue", "light": "snesBlue" },
    "secondary": { "dark": "snesRed", "light": "snesRed" },
    "accent": { "dark": "snesYellow", "light": "snesYellow" },
    "error": { "dark": "snesRed", "light": "snesRed" },
    "warning": { "dark": "snesYellow", "light": "snesYellow" },
