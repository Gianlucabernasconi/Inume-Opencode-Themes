{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#000000",
    "surface": "#000000",
    "neutral": "#808080",
    "accent": "#00FFFF",
    "warm": "#FF00FF",
    "highlight": "#FFFFFF",
    "text": "#FFFFFF",
    "success": "#00FF00",
    "error": "#FF0000",
    "warning": "#00FFFF",
    "info": "#00FFFF",
    "shadowDark": "#000000",
    "cgaCyan": "#00FFFF",
    "cgaMagenta": "#FF00FF",
    "cgaWhite": "#FFFFFF",
    "cgaBlack": "#000000",
    "cgaGreen": "#00FF00",
    "cgaRed": "#FF0000"
  },
  "theme": {
    "primary": { "dark": "accent", "light": "accent" },
    "secondary": { "dark": "warm", "light": "warm" },
    "accent": { "dark": "highlight", "light": "highlight" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "warning" },
    "success": { "dark": "success", "light": "success" },
    "info": { "dark": "info", "light": "info" },
    "text": { "dark": "text", "light": "text" },
    "textMuted": { "dark": "neutral", "light": "neutral" },
    "background": { "dark": "bg", "light": "bg" },
    "backgroundPanel": { "dark": "surface", "light": "surface" },
    "backgroundElement": { "dark": "surface", "light": "surface" },
    "border": { "dark": "neutral", "light": "neutral" },
    "borderActive": { "dark": "accent", "light": "accent" },
    "borderSubtle": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "diffAdded": { "dark": "success", "light": "success" },
    "diffRemoved": { "dark": "error", "light": "error" },
    "diffContext": { "dark": "neutral", "light": "neutral" },
    "diffHunkHeader": { "dark": "neutral", "light": "neutral" },
    "diffHighlightAdded": { "dark": "success", "light": "success" },
    "diffHighlightRemoved": { "dark": "error", "light": "error" },
    "diffAddedBg": { "dark": "#003300", "light": "#003300" },
    "diffRemovedBg": { "dark": "#330000", "light": "#330000" },
    "diffContextBg": { "dark": "surface", "light": "surface" },
    "diffLineNumber": { "dark": "neutral", "light": "neutral" },
    "diffAddedLineNumberBg": { "dark": "#003300", "light": "#003300" },
    "diffRemovedLineNumberBg": { "dark": "#330000", "light": "#330000" },
    "markdownText": { "dark": "text", "light": "text" },
    "markdownHeading": { "dark": "accent", "light": "accent" },
    "markdownLink": { "dark": "accent", "light": "accent" },
    "markdownLinkText": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "markdownCode": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "markdownBlockQuote": { "dark": "neutral", "light": "neutral" },
    "markdownEmph": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "markdownStrong": { "dark": "highlight", "light": "highlight" },
    "markdownHorizontalRule": { "dark": "neutral", "light": "neutral" },
    "markdownListItem": { "dark": "accent", "light": "accent" },
    "markdownListEnumeration": { "dark": "highlight", "light": "highlight" },
    "markdownImage": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "markdownImageText": { "dark": "highlight", "light": "highlight" },
    "markdownCodeBlock": { "dark": "text", "light": "text" },
    "syntaxComment": { "dark": "neutral", "light": "neutral" },
    "syntaxKeyword": { "dark": "accent", "light": "accent" },
    "syntaxFunction": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "syntaxVariable": { "dark": "text", "light": "text" },
    "syntaxString": { "dark": "cgaMagenta", "light": "cgaMagenta" },
    "syntaxNumber": { "dark": "cgaGreen", "light": "cgaGreen" },
    "syntaxType": { "dark": "accent", "light": "accent" },
    "syntaxOperator": { "dark": "text", "light": "text" },
    "syntaxPunctuation": { "dark": "neutral", "light": "neutral" }
  }
}
