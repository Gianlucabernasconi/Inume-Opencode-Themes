{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "desktop": "#008080",
    "surface": "#C0C0C0",
    "shadow": "#808080",
    "title": "#000080",
    "light": "#DFDFDF",
    "highlight": "#FFFFFF",
    "text": "#000000",
    "success": "#008000",
    "error": "#800000",
    "warning": "#808000",
    "info": "#000080",
    "shadowDark": "#404040",
    "diffAddedBg": "#DFF0DF",
    "diffRemovedBg": "#F0DFDF"
  },
  "theme": {
    "primary": { "dark": "title", "light": "title" },
    "secondary": { "dark": "light", "light": "light" },
    "accent": { "dark": "highlight", "light": "highlight" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "warning" },
    "success": { "dark": "success", "light": "success" },
    "info": { "dark": "info", "light": "info" },
    "text": { "dark": "text", "light": "text" },
    "textMuted": { "dark": "shadowDark", "light": "shadowDark" },
    "background": { "dark": "desktop", "light": "desktop" },
    "backgroundPanel": { "dark": "surface", "light": "surface" },
    "backgroundElement": { "dark": "surface", "light": "surface" },
    "border": { "dark": "shadow", "light": "shadow" },
    "borderActive": { "dark": "title", "light": "title" },
    "borderSubtle": { "dark": "light", "light": "light" },
    "diffAdded": { "dark": "success", "light": "success" },
    "diffRemoved": { "dark": "error", "light": "error" },
    "diffContext": { "dark": "shadowDark", "light": "shadowDark" },
    "diffHunkHeader": { "dark": "title", "light": "title" },
    "diffHighlightAdded": { "dark": "success", "light": "success" },
    "diffHighlightRemoved": { "dark": "error", "light": "error" },
    "diffAddedBg": { "dark": "diffAddedBg", "light": "diffAddedBg" },
    "diffRemovedBg": { "dark": "diffRemovedBg", "light": "diffRemovedBg" },
    "diffContextBg": { "dark": "surface", "light": "surface" },
    "diffLineNumber": { "dark": "shadowDark", "light": "shadowDark" },
    "diffAddedLineNumberBg": { "dark": "diffAddedBg", "light": "diffAddedBg" },
    "diffRemovedLineNumberBg": { "dark": "diffRemovedBg", "light": "diffRemovedBg" },
    "markdownText": { "dark": "text", "light": "text" },
    "markdownHeading": { "dark": "title", "light": "title" },
    "markdownLink": { "dark": "title", "light": "title" },
    "markdownLinkText": { "dark": "title", "light": "title" },
    "markdownCode": { "dark": "error", "light": "error" },
    "markdownBlockQuote": { "dark": "shadow", "light": "shadow" },
    "markdownEmph": { "dark": "shadowDark", "light": "shadowDark" },
    "markdownStrong": { "dark": "text", "light": "text" },
    "markdownHorizontalRule": { "dark": "shadow", "light": "shadow" },
    "markdownListItem": { "dark": "title", "light": "title" },
    "markdownListEnumeration": { "dark": "title", "light": "title" },
    "markdownImage": { "dark": "shadowDark", "light": "shadowDark" },
    "markdownImageText": { "dark": "text", "light": "text" },
    "markdownCodeBlock": { "dark": "text", "light": "text" },
    "syntaxComment": { "dark": "shadowDark", "light": "shadowDark" },
    "syntaxKeyword": { "dark": "title", "light": "title" },
    "syntaxFunction": { "dark": "error", "light": "error" },
    "syntaxVariable": { "dark": "text", "light": "text" },
    "syntaxString": { "dark": "error", "light": "error" },
    "syntaxNumber": { "dark": "warning", "light": "warning" },
    "syntaxType": { "dark": "title", "light": "title" },
    "syntaxOperator": { "dark": "text", "light": "text" },
    "syntaxPunctuation": { "dark": "shadowDark", "light": "shadowDark" }
  }
}
